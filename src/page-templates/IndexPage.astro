---
import { getCollection } from 'astro:content';
import BlogLayout from '../layouts/BlogLayout.astro';
import PostCard from '../components/PostCard.astro';
import { POSTS_PER_PAGE, excludeResearchNotes, filterByLocale, filterPublished, formatDate, getPostSlug, sortPosts } from '../utils/blog';
import type { Locale } from '../utils/i18n';
import { getDictionary, otherLocale } from '../utils/i18n';
import homeSearchScript from '../scripts/home-search.js?url';

interface Props {
	locale: Locale;
	basePath?: string;
}

const { locale, basePath = '' } = Astro.props as Props;
const dictionary = getDictionary(locale);
const allPosts = sortPosts((await getCollection('posts')).filter(filterPublished).filter(filterByLocale(locale)));
const posts = allPosts.filter(excludeResearchNotes);
const featuredPosts = posts.filter((post) => post.data.featured);
const paginatedPosts = posts.slice(0, POSTS_PER_PAGE);
const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));
const heroPost = featuredPosts[0] ?? posts[0];
const feedPosts = heroPost ? paginatedPosts.filter((post) => getPostSlug(post) !== getPostSlug(heroPost)) : paginatedPosts;
const altLocale = otherLocale(locale);
const alternateHref = altLocale === 'es' ? '/es' : '/';
const alternateLabel = dictionary.navigation.locales[altLocale].aria;
const defaultCountLabel = dictionary.search.countResults.replace('{count}', String(posts.length));
const archiveIntro = locale === 'es'
	? 'Notas técnicas con ejemplos reproducibles, límites claros y decisiones de implementación.'
	: 'Technical notes with reproducible examples, clear boundaries, and implementation decisions.';
const archiveKicker = locale === 'es' ? 'Archivo Build' : 'Build archive';
const archiveTitle = locale === 'es'
	? 'Notas de ingeniería para cambiar software con cuidado.'
	: 'Engineering notes for changing software with care.';
const postCountLabel = locale === 'es' ? `${posts.length} notas` : `${posts.length} posts`;
const protocolLabel = locale === 'es' ? 'Ciclo de cambio' : 'Change loop';
const protocolSteps = locale === 'es'
	? ['Inspeccionar', 'Cambiar', 'Verificar']
	: ['Inspect', 'Change', 'Verify'];
const base = basePath === '/' ? '' : basePath;
const buildHref = (path: string) => {
	const normalized = path.startsWith('/') ? path : `/${path}`;
	return `${base}${normalized}`.replace(/\/{2,}/g, '/');
};

const stripMarkdown = (value: string) =>
	value
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/`[^`]*`/g, ' ')
		.replace(/!\[[^\]]*]\([^)]*\)/g, ' ')
		.replace(/\[[^\]]*]\([^)]*\)/g, ' ')
		.replace(/[#>*_~]/g, ' ')
		.replace(/<\/?[^>]+(>|$)/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();

const escapeForScript = (payload: unknown) => JSON.stringify(payload).replace(/</g, '\\u003c');

const searchDocuments = posts.map((post) => {
	const slug = getPostSlug(post);
	const bodyText = stripMarkdown(post.body ?? '');
	return {
		id: slug,
		title: post.data.title,
		description: post.data.description,
		tags: post.data.tags,
		body: bodyText || post.data.description,
		href: buildHref(`/blog/${slug}`),
		dateLabel: formatDate(post.data.date, locale),
	};
});

const searchDataScript = escapeForScript(searchDocuments);
const searchConfigScript = escapeForScript({
	countResults: dictionary.search.countResults,
	defaultCount: defaultCountLabel,
	readMoreLabel: dictionary.buttons.readMore,
	tagsLabel: dictionary.postPage.tagsLabel,
});
---

<BlogLayout
	title={dictionary.site.title}
	description={dictionary.site.description}
	locale={locale}
	dictionary={dictionary}
	basePath={basePath}
	alternateHref={alternateHref}
	alternateLabel={alternateLabel}
>
	{heroPost && (
		<a class="hero-card" href={buildHref(`/blog/${getPostSlug(heroPost)}`)}>
			<p class="hero-kicker">{dictionary.sections.featuredTitle}</p>
			<h1>{heroPost.data.title}</h1>
			<p class="hero-subtitle">{heroPost.data.description}</p>
			<span class="hero-hint">{dictionary.buttons.readMore} →</span>
		</a>
	)}

	<section class="feed">
		<div class="archive-panel">
			<div class="feed-heading">
				<p class="feed-kicker">{archiveKicker}</p>
				<h2 id="build-archive-title">{archiveTitle}</h2>
				<p>{archiveIntro}</p>
			</div>
			<div class="archive-meta" aria-label={protocolLabel}>
				<span class="feed-count">{postCountLabel}</span>
				<div class="protocol-steps">
					{protocolSteps.map((step, index) => (
						<>
							<span class="protocol-step">{step}</span>
							{index < protocolSteps.length - 1 && <span class="protocol-arrow" aria-hidden="true">→</span>}
						</>
					))}
				</div>
			</div>
			<div class="search-inline">
				<label class="sr-only" for="home-search">{dictionary.search.label}</label>
				<div class="search-input-row">
					<input
						id="home-search"
						type="search"
						class="search-input"
						name="home-search"
						placeholder={dictionary.search.placeholder}
						autocomplete="off"
						data-search-input
					/>
					<button class="pill subtle search-clear" type="button" data-search-clear aria-label={dictionary.search.clear}>
						{dictionary.search.clear}
					</button>
				</div>
				<p class="search-count" data-search-count>{defaultCountLabel}</p>
			</div>
		</div>
		<p class="search-empty" data-search-empty hidden>{dictionary.search.empty}</p>
		<div class="feed-list search-results" data-search-grid hidden></div>
		<div class="feed-list" data-post-grid>
			{feedPosts.map((post) => (
				<PostCard post={post} locale={locale} basePath={basePath} dictionary={dictionary} variant="list" />
			))}
		</div>

		{totalPages > 1 && (
			<nav class="pagination" aria-label="Pagination" data-pagination>
				<span class="pagination-label">{dictionary.pagination.label} 1 / {totalPages}</span>
				<a class="pill subtle" href={`${basePath}/page/2`}>{dictionary.pagination.next}</a>
			</nav>
		)}
	</section>
</BlogLayout>

<script type="application/json" id="home-search-data" set:html={searchDataScript}></script>
<script type="application/json" id="home-search-config" set:html={searchConfigScript}></script>
<div hidden aria-hidden="true" data-card-templates>
	{posts.map((post) => (
		<template data-card-template data-slug={getPostSlug(post)}>
			<PostCard post={post} locale={locale} basePath={basePath} dictionary={dictionary} variant="list" />
		</template>
	))}
</div>
<script src="/vendor/fuse.min.js" is:inline></script>
<script type="module" src={homeSearchScript}></script>

<style>
.hero-card {
	margin-top: 2rem;
	padding: 1.75rem;
	border: 1px solid var(--border);
	border-radius: var(--radius-lg);
	background: linear-gradient(135deg, color-mix(in srgb, var(--surface-card) 88%, transparent), var(--surface-elevated));
	box-shadow: var(--shadow-soft);
	display: block;
	text-decoration: none;
	color: inherit;
	transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
	position: relative;
	cursor: pointer;
}

.hero-card:hover,
.hero-card:focus-visible {
	border-color: var(--accent);
	box-shadow: var(--shadow-card);
	transform: translateY(-2px);
	outline: none;
}

.hero-card::after {
	content: '↗';
	position: absolute;
	top: 1.25rem;
	right: 1.25rem;
	width: 2rem;
	height: 2rem;
	border-radius: 999px;
	border: 1px solid var(--border);
	display: grid;
	place-items: center;
	color: var(--text-muted);
	background: var(--surface-elevated);
	transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease;
}

.hero-card:hover::after,
.hero-card:focus-visible::after {
	transform: translate(2px, -2px);
	border-color: var(--accent);
	color: var(--accent);
}

.hero-kicker {
	margin: 0 0 0.65rem;
	font-size: 0.85rem;
	letter-spacing: 0.12em;
	text-transform: uppercase;
	color: var(--text-muted);
}

.hero-card h1 {
	margin: 0;
	font-family: var(--font-heading);
	font-size: clamp(2rem, 3vw, 2.8rem);
}

.hero-subtitle {
	margin: 0.75rem 0 1.25rem;
	color: var(--text-muted);
}

.hero-hint {
	display: inline-flex;
	align-items: center;
	gap: 0.35rem;
	font-size: 0.95rem;
	color: var(--text-base);
	font-weight: 600;
}

.hero-cta {
	display: inline-flex;
	align-items: center;
	gap: 0.4rem;
}

.feed {
	margin-top: 1.75rem;
	display: flex;
	flex-direction: column;
	gap: 1.2rem;
}

.archive-panel {
	display: grid;
	grid-template-columns: minmax(0, 1fr) auto;
	gap: 1rem 1.25rem;
	align-items: end;
	padding: 1.15rem;
	border: 1px solid var(--border);
	border-radius: var(--radius-lg);
	background:
		linear-gradient(90deg, color-mix(in srgb, var(--accent) 7%, transparent), transparent 34%),
		var(--surface-card);
	box-shadow: var(--shadow-soft);
}

.feed-heading {
	display: flex;
	flex-direction: column;
	gap: 0.35rem;
}

.feed-heading h2 {
	margin: 0;
	font-family: var(--font-heading);
	font-size: clamp(1.45rem, 2.25vw, 2.05rem);
	line-height: 1.1;
}

.feed-heading p {
	margin: 0;
	color: var(--text-muted);
	max-width: 58ch;
}

.feed-kicker {
	margin: 0;
	font-size: 0.78rem;
	letter-spacing: 0.14em;
	text-transform: uppercase;
	font-weight: 700;
	color: var(--accent) !important;
}

.archive-meta {
	display: flex;
	flex-direction: column;
	align-items: flex-end;
	gap: 0.55rem;
}

.feed-count {
	flex-shrink: 0;
	border: 1px solid var(--border);
	border-radius: var(--radius-pill);
	background: var(--surface-card);
	padding: 0.4rem 0.75rem;
	font-size: 0.9rem;
	color: var(--text-muted);
	box-shadow: var(--shadow-soft);
}

.protocol-steps {
	display: flex;
	align-items: center;
	justify-content: flex-end;
	gap: 0.35rem;
	font-family: var(--font-mono);
	font-size: 0.72rem;
	letter-spacing: 0.08em;
	text-transform: uppercase;
	color: var(--text-muted);
}

.protocol-step {
	border: 1px solid var(--border);
	border-radius: var(--radius-pill);
	background: var(--surface-elevated);
	padding: 0.28rem 0.48rem;
}

.protocol-arrow {
	color: color-mix(in srgb, var(--accent) 65%, var(--text-muted));
}

.pagination {
	margin-top: 2.25rem;
	display: flex;
	gap: 0.75rem;
	align-items: center;
}

.pagination-label {
	color: var(--text-muted);
}

.search-inline {
	grid-column: 1 / -1;
	padding-top: 0.15rem;
}

.search-input-row {
	display: flex;
	gap: 0.75rem;
	align-items: center;
}

.search-input {
	flex: 1;
	border: 1px solid var(--border);
	border-radius: var(--radius-pill);
	padding: 0.65rem 1rem;
	font-size: 1rem;
	background: var(--surface-elevated);
	color: var(--text-base);
	box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--surface-elevated) 70%, var(--border));
}

.search-input:focus {
	outline: 2px solid var(--accent);
	outline-offset: 2px;
}

.search-input-row .pill {
	border-radius: var(--radius-pill);
	box-shadow: none;
}

.search-inline:focus-within {
	border-color: color-mix(in srgb, var(--accent) 55%, var(--border));
	box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 20%, transparent);
}

.search-clear[hidden] {
	display: none;
}

.search-count {
	margin: 0.6rem 0 0;
	color: var(--text-muted);
	font-size: 0.95rem;
}

.search-empty {
	margin-top: 1.35rem;
	padding: 1rem;
	border-radius: var(--radius-lg);
	border: 1px dashed var(--border);
	text-align: center;
	background: var(--surface-card);
	color: var(--text-muted);
}

.feed-list {
	display: flex;
	flex-direction: column;
	gap: 0.9rem;
}

@media (max-width: 600px) {
	.archive-panel {
		grid-template-columns: 1fr;
		align-items: start;
		padding: 1rem;
	}

	.feed-heading {
		align-items: flex-start;
	}

	.archive-meta {
		align-items: flex-start;
	}

	.protocol-steps {
		justify-content: flex-start;
		flex-wrap: wrap;
	}

	.search-input-row {
		flex-direction: column;
		align-items: stretch;
	}

	.search-clear {
		width: 100%;
	}
}
</style>
