---
import BlogLayout from '../layouts/BlogLayout.astro';
import PostCard from '../components/PostCard.astro';
import type { TagSummary } from '../utils/blog';
import type { Locale } from '../utils/i18n';
import { getDictionary, otherLocale } from '../utils/i18n';

interface Props {
	locale: Locale;
	basePath?: string;
	summary: TagSummary;
}

const { locale, basePath = '', summary } = Astro.props as Props;
const dictionary = getDictionary(locale);
const altLocale = otherLocale(locale);
const alternateHref = altLocale === 'es' ? '/es/tags' : '/tags';
const alternateLabel = dictionary.navigation.locales[altLocale].aria;
const detailKicker = locale === 'es' ? 'Archivo por tema' : 'Topic archive';
const resultLabel = locale === 'es'
	? `${summary.count} notas en este tema`
	: `${summary.count} notes in this topic`;
---

<BlogLayout
	title={`${dictionary.tagsPage.title}: ${summary.label} | ${dictionary.site.title}`}
	description={`${dictionary.tagsPage.title}: ${summary.label}`}
	locale={locale}
	dictionary={dictionary}
	basePath={basePath}
	alternateHref={alternateHref}
	alternateLabel={alternateLabel}
>
	<section class="tag-detail" aria-labelledby="tag-detail-title">
		<header class="topic-hero">
			<p class="back-link"><a href={`${basePath}/tags`}>← {dictionary.tagsPage.backLabel}</a></p>
			<p class="topic-kicker">{detailKicker}</p>
			<div class="topic-title-row">
				<h1 id="tag-detail-title">{summary.label}</h1>
				<span class="topic-count">{resultLabel}</span>
			</div>
		</header>
		<div class="feed-list">
			{summary.posts.map((post) => (
				<PostCard post={post} locale={locale} basePath={basePath} dictionary={dictionary} variant="list" />
			))}
		</div>
	</section>
</BlogLayout>

<style>
.tag-detail {
	margin-top: 1.75rem;
	display: flex;
	flex-direction: column;
	gap: 1rem;
}

.topic-hero {
	padding: clamp(1.2rem, 3vw, 1.6rem);
	border: 1px solid var(--border);
	border-radius: var(--radius-lg);
	background:
		linear-gradient(90deg, color-mix(in srgb, var(--accent) 8%, transparent), transparent 42%),
		var(--surface-card);
	box-shadow: var(--shadow-soft);
}

.back-link {
	margin: 0 0 1rem;
}

.back-link a {
	color: var(--text-muted);
	text-decoration: none;
}

.back-link a:hover,
.back-link a:focus-visible {
	color: var(--text-base);
	text-decoration: underline;
}

.topic-kicker {
	margin: 0 0 0.4rem;
	font-family: var(--font-code);
	font-size: 0.78rem;
	font-weight: 700;
	letter-spacing: 0.14em;
	text-transform: uppercase;
	color: var(--accent);
}

.topic-title-row {
	display: flex;
	align-items: end;
	justify-content: space-between;
	gap: 1rem;
	flex-wrap: wrap;
}

h1 {
	margin: 0;
	font-family: var(--font-heading);
	font-size: clamp(2rem, 4.5vw, 3.25rem);
	letter-spacing: -0.04em;
	line-height: 1;
}

.topic-count {
	border: 1px solid var(--border);
	border-radius: var(--radius-pill);
	background: var(--surface-card);
	padding: 0.4rem 0.75rem;
	font-size: 0.9rem;
	color: var(--text-muted);
	box-shadow: var(--shadow-soft);
}

.feed-list {
	display: flex;
	flex-direction: column;
	gap: 0.9rem;
}
</style>
