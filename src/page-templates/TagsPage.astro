---
import BlogLayout from '../layouts/BlogLayout.astro';
import type { TagSummary } from '../utils/blog';
import type { Locale } from '../utils/i18n';
import { getDictionary, otherLocale } from '../utils/i18n';

interface Props {
	locale: Locale;
	basePath?: string;
	tags: TagSummary[];
}

const { locale, basePath = '', tags } = Astro.props as Props;
const dictionary = getDictionary(locale);
const altLocale = otherLocale(locale);
const alternateHref = altLocale === 'es' ? '/es/tags' : '/tags';
const alternateLabel = dictionary.navigation.locales[altLocale].aria;
const tagsKicker = locale === 'es' ? 'Mapa Build' : 'Build map';
const topicCountLabel = locale === 'es' ? `${tags.length} temas` : `${tags.length} topics`;
const mapFrameLabel = locale === 'es' ? 'Agrupar' : 'Cluster';
const mapFrameSteps = locale === 'es'
	? ['Lenguaje', 'Herramientas', 'Práctica']
	: ['Language', 'Tools', 'Practice'];
---

<BlogLayout
	title={`${dictionary.tagsPage.title} | ${dictionary.site.title}`}
	description={dictionary.tagsPage.description}
	locale={locale}
	dictionary={dictionary}
	basePath={basePath}
	alternateHref={alternateHref}
	alternateLabel={alternateLabel}
>
	<section class="tag-map" aria-labelledby="tag-map-title">
		<header class="tag-map-hero">
			<div class="tag-map-copy">
				<p class="tag-map-kicker">{tagsKicker}</p>
				<h1 id="tag-map-title">{dictionary.tagsPage.title}</h1>
				<p class="lede">{dictionary.tagsPage.description}</p>
			</div>
			<div class="map-meta" aria-label={mapFrameLabel}>
				<span class="topic-count">{topicCountLabel}</span>
				<div class="map-frame">
					{mapFrameSteps.map((step, index) => (
						<>
							<span>{step}</span>
							{index < mapFrameSteps.length - 1 && <span aria-hidden="true">/</span>}
						</>
					))}
				</div>
			</div>
		</header>
		{tags.length === 0 ? (
			<p class="muted">{dictionary.tagsPage.empty}</p>
		) : (
			<ul class="tag-list">
				{tags.map((tag) => (
					<li>
						<a href={`${basePath}/tags/${tag.slug}`}>
							<span class="tag-name">{tag.label}</span>
							<span class="tag-line" aria-hidden="true"></span>
							<span class="count">{tag.count} {dictionary.tagsPage.countLabel}</span>
						</a>
					</li>
				))}
			</ul>
		)}
	</section>
</BlogLayout>

<style>
.tag-map {
	margin-top: 1.75rem;
}

.tag-map-hero {
	display: grid;
	grid-template-columns: minmax(0, 1fr) auto;
	gap: 1rem 1.25rem;
	align-items: end;
	padding: clamp(1.25rem, 3vw, 1.65rem);
	border: 1px solid var(--border);
	border-radius: var(--radius-lg);
	background:
		linear-gradient(90deg, color-mix(in srgb, var(--accent) 8%, transparent), transparent 40%),
		var(--surface-card);
	box-shadow: var(--shadow-soft);
}

.tag-map-kicker {
	margin: 0 0 0.45rem;
	font-family: var(--font-code);
	font-size: 0.78rem;
	font-weight: 700;
	letter-spacing: 0.14em;
	text-transform: uppercase;
	color: var(--accent);
}

h1 {
	margin: 0;
	font-family: var(--font-heading);
	font-size: clamp(2rem, 4.5vw, 3.2rem);
	letter-spacing: -0.04em;
}

.lede {
	margin: 0.45rem 0 0;
	color: var(--text-muted);
	max-width: 58ch;
}

.map-meta {
	display: flex;
	flex-direction: column;
	align-items: flex-end;
	gap: 0.55rem;
}

.topic-count {
	border: 1px solid var(--border);
	border-radius: var(--radius-pill);
	background: var(--surface-elevated);
	padding: 0.4rem 0.75rem;
	font-size: 0.9rem;
	color: var(--text-muted);
}

.map-frame {
	display: inline-flex;
	gap: 0.45rem;
	font-family: var(--font-code);
	font-size: 0.72rem;
	letter-spacing: 0.08em;
	text-transform: uppercase;
	color: var(--text-muted);
}

.muted {
	margin-top: 1.25rem;
	color: var(--text-muted);
}

.tag-list {
	list-style: none;
	padding: 0;
	margin: 1.15rem 0 0;
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
	gap: 0.85rem;
}

.tag-list a {
	display: grid;
	grid-template-columns: minmax(0, 1fr) auto;
	grid-template-areas:
		'name count'
		'line line';
	align-items: center;
	gap: 0.55rem 0.85rem;
	padding: 0.95rem 1rem;
	background: color-mix(in srgb, var(--surface-card) 98%, var(--surface-contrast));
	border-radius: 14px;
	text-decoration: none;
	color: var(--text-base);
	border: 1px solid var(--border);
	box-shadow: var(--shadow-soft);
	transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
}

.tag-list a:hover,
.tag-list a:focus-visible {
	transform: translateY(-2px);
	border-color: var(--accent);
	box-shadow: var(--shadow-card);
	background: var(--surface-card);
}

.tag-name {
	grid-area: name;
	font-weight: 700;
}

.tag-line {
	grid-area: line;
	height: 3px;
	border-radius: var(--radius-pill);
	background: linear-gradient(90deg, color-mix(in srgb, var(--accent) 65%, transparent), transparent);
}

.count {
	grid-area: count;
	font-size: 0.88rem;
	font-weight: 700;
	color: var(--text-muted);
	white-space: nowrap;
}

@media (max-width: 640px) {
	.tag-map-hero {
		grid-template-columns: 1fr;
		align-items: start;
	}

	.map-meta {
		align-items: flex-start;
	}

	.map-frame {
		flex-wrap: wrap;
	}
}
</style>
