---
import BlogLayout from '../layouts/BlogLayout.astro';
import PostCard from '../components/PostCard.astro';
import type { PostEntry } from '../utils/blog';
import type { Locale } from '../utils/i18n';
import { getDictionary, otherLocale } from '../utils/i18n';

interface Props {
	locale: Locale;
	basePath?: string;
	pagePosts: PostEntry[];
	currentPage: number;
	totalPages: number;
}

const { locale, basePath = '', pagePosts, currentPage, totalPages } = Astro.props as Props;
const dictionary = getDictionary(locale);
const altLocale = otherLocale(locale);
const alternateHref = altLocale === 'es' ? '/es' : '/';
const alternateLabel = dictionary.navigation.locales[altLocale].aria;

const prevHref = currentPage <= 2 ? `${basePath}/` : `${basePath}/page/${currentPage - 1}`;
const nextHref = `${basePath}/page/${currentPage + 1}`;
const archiveKicker = locale === 'es' ? 'Archivo Build' : 'Build archive';
const pageLabel = `${dictionary.pagination.label} ${currentPage} / ${totalPages}`;
const archiveTitle = locale === 'es'
	? 'Más notas de ingeniería del archivo.'
	: 'More engineering notes from the archive.';
---

<BlogLayout
	title={`${dictionary.pagination.label} ${currentPage} | ${dictionary.site.title}`}
	description={dictionary.site.description}
	locale={locale}
	dictionary={dictionary}
	basePath={basePath}
	alternateHref={alternateHref}
	alternateLabel={alternateLabel}
>
	<section class="archive-page" aria-labelledby="archive-page-title">
		<header class="archive-hero">
			<div>
				<p class="archive-kicker">{archiveKicker}</p>
				<h1 id="archive-page-title">{archiveTitle}</h1>
			</div>
			<span class="page-count">{pageLabel}</span>
		</header>
		<div class="feed-list">
			{pagePosts.map((post) => (
				<PostCard post={post} locale={locale} basePath={basePath} dictionary={dictionary} variant="list" />
			))}
		</div>
		<nav class="pagination" aria-label="Pagination">
			{currentPage > 1 ? (
				<a class="pill subtle" href={prevHref}>{dictionary.pagination.previous}</a>
			) : (
				<span class="pill subtle disabled">{dictionary.pagination.previous}</span>
			)}
			<span class="pagination-label">{pageLabel}</span>
			{currentPage < totalPages ? (
				<a class="pill subtle" href={nextHref}>{dictionary.pagination.next}</a>
			) : (
				<span class="pill subtle disabled">{dictionary.pagination.next}</span>
			)}
		</nav>
	</section>
</BlogLayout>

<style>
.archive-page {
	margin-top: 1.75rem;
	display: flex;
	flex-direction: column;
	gap: 1rem;
}

.archive-hero {
	display: flex;
	align-items: end;
	justify-content: space-between;
	gap: 1rem;
	flex-wrap: wrap;
	padding: clamp(1.2rem, 3vw, 1.6rem);
	border: 1px solid var(--border);
	border-radius: var(--radius-lg);
	background:
		linear-gradient(90deg, color-mix(in srgb, var(--accent) 8%, transparent), transparent 42%),
		var(--surface-card);
	box-shadow: var(--shadow-soft);
}

.archive-kicker {
	margin: 0 0 0.4rem;
	font-family: var(--font-code);
	font-size: 0.78rem;
	font-weight: 700;
	letter-spacing: 0.14em;
	text-transform: uppercase;
	color: var(--accent);
}

h1 {
	margin: 0;
	font-family: var(--font-heading);
	font-size: clamp(1.8rem, 3.8vw, 2.8rem);
	letter-spacing: -0.04em;
	line-height: 1.05;
}

.page-count {
	border: 1px solid var(--border);
	border-radius: var(--radius-pill);
	background: var(--surface-card);
	padding: 0.4rem 0.75rem;
	font-size: 0.9rem;
	color: var(--text-muted);
	box-shadow: var(--shadow-soft);
}

.feed-list {
	display: flex;
	flex-direction: column;
	gap: 0.9rem;
}

.pagination {
	margin-top: 1.25rem;
	display: flex;
	gap: 0.75rem;
	align-items: center;
	flex-wrap: wrap;
}

.pill.disabled {
	opacity: 0.6;
	pointer-events: none;
}

.pagination-label {
	color: var(--text-muted);
}
</style>
